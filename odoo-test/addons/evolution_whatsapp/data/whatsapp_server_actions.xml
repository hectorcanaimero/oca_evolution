<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="action_server_whatsapp_send_partner" model="ir.actions.server">
            <field name="name">Enviar por WhatsApp</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="binding_model_id" ref="base.model_res_partner"/>
            <field name="binding_view_types">form,list</field>
            <field name="binding_type">action</field>
            <field name="state">code</field>
            <field name="code">action = env['whatsapp.composer'].action_open_for_records(records)</field>
            <field name="groups_id" eval="[(4, ref('group_evolution_user'))]"/>
        </record>
    </data>
</odoo>
